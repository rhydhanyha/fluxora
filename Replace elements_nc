import java.util.Arrays;

class Solution {
    public static void main(String[] args) {
        int[] arr = {17,18,5,4,6,1};
        int max = -1;
        for(int i=arr.length-1;i>=0;i--){
            int t=arr[i]; arr[i]=max; max=Math.max(max,t);
        }
        System.out.println(Arrays.toString(arr)); 
    }
}
